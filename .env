_ROS_USER=theseus

# ROS 2 Network Configuration
_ROS_DOMAIN_ID=0
_ROS_STATIC_PEERS=

# Discovery Server (optional)
# _DISCOVERY_SERVER_LIST=

# Super Client (optional)
# _ROS_SUPER_CLIENT=false

# Display configuration (for X11 forwarding)
# DISPLAY=:0

# UID for volume permissions (should match your host user)
# UID=1000
